# =============================================================================
# Demo ING-Software · Environment-Vars für Vercel-Deployment
# =============================================================================
# Lokal:  Datei nach .env.local kopieren und Werte einsetzen.
# Vercel: in Project Settings → Environment Variables eintragen.

# -----------------------------------------------------------------------------
# Postgres-Datenbank (Pflicht)
# -----------------------------------------------------------------------------
# Vercel-Empfehlung: Neon (1-Click-Integration im Vercel Marketplace) oder
# Vercel Postgres. Free-Tier bei Neon: 0.5 GB Storage — reicht für die Demo.
# Format: postgres://user:password@host/database?sslmode=require
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# Auth.js (Pflicht)
# -----------------------------------------------------------------------------
# Verschlüsselt das Session-Cookie. Mit `npx auth secret` oder
# `openssl rand -base64 32` generieren. Lokal und auf Vercel separat setzen.
AUTH_SECRET=replace-with-32-byte-random-string

# -----------------------------------------------------------------------------
# Vercel Blob (für File-Uploads — auf Vercel automatisch via Storage-Tab)
# -----------------------------------------------------------------------------
# Vercel: Bei aktivem Blob-Store wird BLOB_READ_WRITE_TOKEN automatisch gesetzt.
# Lokal: aus dem Vercel-Dashboard kopieren, falls Vercel Blob lokal genutzt wird.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Optional · Storage-Driver-Override
# -----------------------------------------------------------------------------
# Default: Vercel-Detektion. Lokal `local-disk`, auf Vercel `vercel-blob`.
# STORAGE_DRIVER=local-disk

# -----------------------------------------------------------------------------
# Optional · KI-Provider (Default: Mock)
# -----------------------------------------------------------------------------
# Recht-Assistent + KI-Floating-Assistent. Default Mock; für Live-Claude:
#   LEGAL_ASSISTANT_PROVIDER=claude
#   KI_ASSISTANT_PROVIDER=claude
# AVV mit Anthropic vor Produktivnutzung: https://www.anthropic.com/legal/dpa
# ANTHROPIC_API_KEY=sk-ant-api03-...
